{
  "version": 2,
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*).(html|js|css|png|jpg|svg|json)",
      "dest": "/public/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
